# ─────────────────────────────────────────────
# AUREUM GOLD — Environment Variables
# ─────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aurum_gold?schema=public"

# Auth (NextAuth.js)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-at-least-32-chars"

# Google OAuth (optional — for Google login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Stripe (payments)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# nFusion Solutions (gold price API)
NFUSION_API_KEY=""

# Resend (transactional email)
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@aureumgold.com"

# Site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="AUREUM GOLD"

# Encryption (AES-256-GCM key for sensitive data)
ENCRYPTION_KEY=""
